/* v10.21.9 â€” Fortnite mascot (Memoji) Homie skin + Hype buddy animations */
.homieMemojiWrap{ position: relative; width: 72px; height: 72px; display:flex; align-items:center; justify-content:center; }
.homieMemojiOuter{ position: relative; width: 72px; height: 72px; display:flex; align-items:center; justify-content:center;
  --homie-look-x: 0px;
  --homie-look-y: 0px;
  --homie-hop: 6px;
  --homie-wiggle-a: -2deg;
  --homie-wiggle-b: 2deg;
}
.homieMemojiInner{ position: relative; width: 84px; height: 84px; display:flex; align-items:center; justify-content:center; transform-origin: 50% 68%; }
.homieMemojiImg{ width: 84px; height: 84px; object-fit: contain; filter: drop-shadow(0 10px 18px rgba(0,0,0,0.28)); user-select:none; pointer-events:none; }
.homieMemojiFx{ position:absolute; right:-10px; bottom:-12px; font-size: 24px; line-height: 1; opacity: 0; transform: translateY(10px) scale(0.8); filter: drop-shadow(0 12px 18px rgba(0,0,0,0.35)); }

.homieOrb.skin-memoji .homieOrbCore{ background: radial-gradient(circle at 35% 30%, rgba(255,209,102,0.18), rgba(94,234,242,0.12) 42%, rgba(8,12,18,0.02) 68%); }

/* Base hype idle: snappy, game-mascot vibe */
.homieMemojiOuter.anim.hype{ animation: homieMascotHypeIdle 1.05s cubic-bezier(0.22, 0.9, 0.26, 1) infinite; }
.homieOrb.skin-memoji.speaking .homieMemojiOuter.anim.hype{ animation-duration: 0.68s; }
.homieOrb.skin-memoji.listening .homieMemojiOuter.anim.hype{ animation-duration: 0.88s; }

@keyframes homieMascotHypeIdle{
  0%,100%{ transform: translate3d(var(--homie-look-x), calc(var(--homie-look-y) + 1px), 0) rotate(var(--homie-wiggle-a)); }
  50%{ transform: translate3d(var(--homie-look-x), calc(var(--homie-look-y) - var(--homie-hop)), 0) rotate(var(--homie-wiggle-b)); }
}

/* Gesture-driven micro emotes */
.homieOrb.skin-memoji.gesture-nod .homieMemojiOuter{ animation: homieMascotNod 640ms ease-in-out 1; }
.homieOrb.skin-memoji.gesture-tilt .homieMemojiOuter{ animation: homieMascotTilt 720ms ease-in-out 1; }
.homieOrb.skin-memoji.gesture-wave .homieMemojiOuter{ animation: homieMascotWave 720ms ease-in-out 1; }
.homieOrb.skin-memoji.gesture-spark .homieMemojiOuter::after{
  content: "âœ¦";
  position:absolute;
  top: -6px;
  right: 4px;
  font-size: 18px;
  opacity: 0;
  transform: translateY(6px) scale(0.6) rotate(-12deg);
  animation: homieMascotSpark 920ms ease-out 1;
  filter: drop-shadow(0 0 10px rgba(255,209,102,0.55));
}
@keyframes homieMascotNod{ 0%{ transform: translate3d(var(--homie-look-x), var(--homie-look-y),0) rotate(0deg);} 35%{ transform: translate3d(var(--homie-look-x), calc(var(--homie-look-y) + 6px),0) rotate(-1deg);} 100%{ transform: translate3d(var(--homie-look-x), var(--homie-look-y),0) rotate(0deg);} }
@keyframes homieMascotTilt{ 0%{ transform: translate3d(var(--homie-look-x), var(--homie-look-y),0) rotate(0deg);} 45%{ transform: translate3d(var(--homie-look-x), calc(var(--homie-look-y) - 3px),0) rotate(6deg);} 100%{ transform: translate3d(var(--homie-look-x), var(--homie-look-y),0) rotate(0deg);} }
@keyframes homieMascotWave{ 0%{ transform: translate3d(var(--homie-look-x), var(--homie-look-y),0) rotate(0deg);} 25%{ transform: translate3d(var(--homie-look-x), calc(var(--homie-look-y) - 2px),0) rotate(-7deg);} 55%{ transform: translate3d(var(--homie-look-x), calc(var(--homie-look-y) - 4px),0) rotate(7deg);} 100%{ transform: translate3d(var(--homie-look-x), var(--homie-look-y),0) rotate(0deg);} }
@keyframes homieMascotSpark{ 0%{ opacity:0; transform: translateY(10px) scale(0.6) rotate(-12deg);} 35%{ opacity:1; transform: translateY(0px) scale(1.05) rotate(10deg);} 100%{ opacity:0; transform: translateY(-8px) scale(0.85) rotate(18deg);} }

/* Big emote FX (fist bump / celebrate / alert / facepalm) */
.homieMemojiOuter.emote-fistbump .homieMemojiFx,
.homieMemojiOuter.emote-celebrate .homieMemojiFx,
.homieMemojiOuter.emote-alert .homieMemojiFx,
.homieMemojiOuter.emote-facepalm .homieMemojiFx{ opacity: 1; animation: homieMascotFxPop 920ms cubic-bezier(0.2,0.9,0.2,1) 1; }

.homieMemojiOuter.emote-celebrate::after{
  content: "âœ¦";
  position:absolute;
  left: 6px;
  top: -8px;
  font-size: 18px;
  opacity: 0;
  animation: homieMascotSpark 920ms ease-out 1;
  filter: drop-shadow(0 0 12px rgba(94,234,242,0.55));
}

@keyframes homieMascotFxPop{
  0%{ opacity:0; transform: translate3d(var(--homie-look-x), calc(var(--homie-look-y) + 10px),0) rotate(0deg) scale(0.92); }
  35%{ opacity:1; transform: translate3d(var(--homie-look-x), calc(var(--homie-look-y) - var(--homie-hop)),0) rotate(var(--homie-wiggle-b)) scale(1.04); }
  100%{ opacity:0; transform: translate3d(var(--homie-look-x), var(--homie-look-y),0) rotate(0deg) scale(1); }
}
