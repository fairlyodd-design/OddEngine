@media (prefers-reduced-motion: reduce){
  .homieOrb,
  .homieOrbRing,
  .homieOrbCore,
  .homieEye,
  .homieMouth,
  .homieLilBody,
  .homieLilHead,
  .homieLilArm,
  .homieLilLeg,
  .deskSteam{ animation: none !important; }
}
