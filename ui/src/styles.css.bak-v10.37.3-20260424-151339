:root{
  --bg:#090914;
  --panel:#131427;
  --panel2:#0d1020;
  --fg:#f6f8ff;
  --muted:#b9bed5;
  --line:#2f2558;
  --lineSoft: rgba(121,87,255,0.22);
  --good:#6cf2cf;
  --bad:#ff7aa7;
  --warn:#ffd166;
  --accent:#5eeaf2;
  --gold:#ffd166;
  --purple:#8f62ff;
  --pink:#ff58c8;
  /* FairlyOdd logo palette (auto-sampled) */
  --fo-deep:#0e094c;
  --fo-violet:#351c7b;
  --fo-pink:#c4327f;
  --fo-magenta:#d365f3;
  --fo-cyan:#3cd5fa;
  --fo-blue:#2558ca;
  --fo-gold:#fbc748;
  --shadow: 0 18px 50px rgba(0,0,0,0.34);

  /* micro-spacing tokens */
  --space-1: 6px;
  --space-2: 8px;
  --space-3: 10px;
  --space-4: 12px;
  --card-pad: 12px;
  --inset-1: 10px;
  --inset-2: 12px;
  --radius-1: 12px;
  --radius-2: 14px;
  --radius-3: 16px;
  --widget-gap: var(--space-2);
  --widget-inset: var(--inset-1);
}


*{ box-sizing:border-box; }
html,body{
  margin:0;
  background:
    radial-gradient(1100px 640px at 10% -10%, rgba(196,50,127,0.22) 0%, rgba(9,9,20,0) 62%),
    radial-gradient(1100px 640px at 85% -10%, rgba(60,213,250,0.18) 0%, rgba(9,9,20,0) 60%),
    radial-gradient(900px 520px at 50% 115%, rgba(251,199,72,0.14) 0%, rgba(9,9,20,0) 60%),
    radial-gradient(880px 520px at 65% 55%, rgba(211,101,243,0.10) 0%, rgba(9,9,20,0) 62%),
    linear-gradient(180deg, #070716 0%, #070717 45%, var(--bg) 100%);
  color:var(--fg);
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
}

a{ color:var(--accent); text-decoration:none; }
code{ color:#c7d2fe; }
button{
  border:1px solid rgba(121,87,255,0.32);
  background: linear-gradient(180deg, rgba(30,24,56,0.96) 0%, rgba(15,16,30,0.96) 100%);
  color:var(--fg);
  padding:10px 12px;
  border-radius:12px;
  cursor:pointer;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
}
button:disabled{ opacity:0.5; cursor:not-allowed; }
input, textarea, select{
  width:100%;
  padding:10px 12px;
  border-radius:12px;
  border:1px solid rgba(121,87,255,0.28);
  background: rgba(10,10,22,0.88);
  color:var(--fg);
}
.small{ font-size:12px; color:var(--muted); }
.row{ display:flex; gap:var(--space-2); align-items:center; }
.row.spread{ justify-content:space-between; }
.row.wrap{ flex-wrap:wrap; }
.row.start{ align-items:flex-start; }
.row.end{ align-items:flex-end; }

.grid{ display:grid; gap:var(--space-2); }
.grid.tight{ gap:var(--space-1); }
.grid.loose{ gap:var(--space-4); }

.stack{ display:flex; flex-direction:column; gap:var(--space-2); min-height:0; }
.stack.tight{ gap:var(--space-1); }
.stack.loose{ gap:var(--space-3); }

.cluster{ display:flex; align-items:center; gap:var(--space-2); }
.cluster.wrap{ flex-wrap:wrap; }
.cluster.spread{ justify-content:space-between; }
.cluster.end{ align-items:flex-end; }
.cluster.start{ align-items:flex-start; }

.mt-0{ margin-top:2px; }
.mt-1{ margin-top:4px; }
.mt-2{ margin-top:6px; }
.mt-3{ margin-top:8px; }
.mt-4{ margin-top:10px; }
.mt-5{ margin-top:12px; }
.mt-6{ margin-top:14px; }
.block{ display:block; }
.row.tight, .cluster.tight{ gap:var(--space-1); }
.row.loose, .cluster.loose{ gap:var(--space-3); }
.flowStack{ display:flex; flex-direction:column; gap:var(--space-2); min-height:0; }
.flowStack.tight{ gap:var(--space-1); }
.flowGrid{ display:grid; gap:var(--space-2); }
.flowGrid.tight{ gap:var(--space-1); }
.tableWrap{ overflow:auto; }

.subCard{ border:1px solid rgba(255,255,255,0.10); border-radius: var(--radius-2); padding: var(--widget-inset); background: rgba(255,255,255,0.03); }
.subCard.dim{ background: rgba(0,0,0,0.18); }
.subCard.glass{ background: linear-gradient(180deg, rgba(12,18,28,0.74) 0%, rgba(8,12,18,0.62) 100%); }
.subCardTitle{ font-weight:900; }
.subCardSub{ font-size:12px; color:var(--muted); opacity:0.88; }
.card{
  border:1px solid rgba(121,87,255,0.22);
  background:
    radial-gradient(700px 240px at 20% 0%, rgba(60,213,250,0.08) 0%, rgba(20,18,44,0) 55%),
    radial-gradient(700px 240px at 90% 10%, rgba(196,50,127,0.08) 0%, rgba(20,18,44,0) 55%),
    rgba(20,18,44,0.78);
  border-radius:16px;
  padding:var(--card-pad);
  box-shadow: var(--shadow);
  backdrop-filter: blur(12px);
}

/* --- Standard widget/card headers (one-piece OS) --- */
.widgetHeader{ display:flex; align-items:center; justify-content:space-between; gap:12px; min-height:44px; }
.widgetHeaderLeft{ min-width:0; display:flex; flex-direction:column; gap:2px; }
.widgetHeaderRight{ display:flex; align-items:center; gap:8px; flex-wrap:nowrap; }
.widgetTitle{ font-weight:900; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.widgetSubtitle{ font-size:12px; color:var(--muted); opacity:0.88; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.widgetBody{ margin-top: var(--space-2); min-height: 0; display:flex; flex-direction:column; gap: var(--widget-gap); }
.panelBody{ margin-top: var(--space-4); }

/* FairlyGOD Mode: global card controls (wired by CardGODMode, scoped to panelMain) */
.godCardControls{
  position:absolute;
  /* Put controls away from most widget header action buttons (Undock/Open/etc.) */
  bottom:10px;
  left:10px;
  display:flex;
  gap:8px;
  z-index:45;
  /* Default hidden so they don't clutter or block clicks */
  opacity:0;
  pointer-events:none;
  transition: opacity 140ms ease, transform 140ms ease;
  transform: translateY(4px);
}
.card:hover .godCardControls{ opacity:1; transform: translateY(0px); }
.godCardControls .godBtn{ pointer-events:auto; }
.godBtn{
  border-radius:999px;
  padding:6px 10px;
  font-size:12px;
  font-weight:800;
  border:1px solid rgba(140,160,190,0.18);
  background: rgba(18,26,40,0.65);
  color: rgba(240,245,255,0.92);
  cursor:pointer;
}
.godBtn:hover{ background: rgba(30,42,64,0.78); }
.godPinned{ border-color: rgba(255,190,90,0.45); }
.godPinBtn{ border-color: rgba(255,190,90,0.22); }
.godPinned .godPinBtn{ background: rgba(255,190,90,0.16); }
.godCollapsed{ max-height:52px; overflow:hidden; }
.godFloating{ outline:1px solid rgba(120,200,255,0.18); box-shadow: 0 18px 44px rgba(0,0,0,0.35); }

/* Make collapsed cards feel intentional (title bar vibe) */
.godCollapsed{
  padding-top:12px;
  padding-bottom:10px;
}
.godCollapsed::after{
  content:"";
  position:absolute;
  left:0; right:0; bottom:0;
  height:26px;
  background: linear-gradient(180deg, rgba(20,18,44,0) 0%, rgba(20,18,44,0.86) 100%);
  pointer-events:none;
}

/* Layout bar + grid + guides */
.panelMain.godGridOn{
  background-image:
    linear-gradient(rgba(255,255,255,0.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.045) 1px, transparent 1px);
  background-size: 16px 16px;
  background-position: 0 0;
}
.panelMain.godLocked .godCardControls .godBtn[data-act="move"],
.panelMain.godLocked .godCardControls .godBtn[data-act="move"]{
  opacity:0.45;
  pointer-events:none;
}
.godLayoutBar{
  position: sticky;
  top: 8px;
  margin-left:auto;
  width: fit-content;
  z-index: 60;
  border:1px solid rgba(140,160,190,0.16);
  background:
    radial-gradient(420px 180px at 30% 0%, rgba(60,213,250,0.10) 0%, rgba(10,14,22,0) 55%),
    radial-gradient(420px 180px at 90% 0%, rgba(211,101,243,0.10) 0%, rgba(10,14,22,0) 55%),
    rgba(10,14,22,0.70);
  backdrop-filter: blur(10px);
  border-radius: 14px;
  padding: 10px 10px;
  display:flex;
  flex-direction: column;
  gap:8px;
}
.godLayoutBarRow{ display:flex; gap:8px; align-items:center; justify-content:flex-end; }
.godLayoutBar.godCollapsed .godAdvanced{ display:none; }
.godLayoutBar.godCollapsed .godLayoutHint{ display:none; }
.godMiniBtn{
  border-radius:999px;
  padding:6px 10px;
  font-size:12px;
  font-weight:900;
  border:1px solid rgba(140,160,190,0.16);
  background: rgba(18,26,40,0.62);
  color: rgba(240,245,255,0.92);
  cursor:pointer;
}
.godMiniBtn:hover{ background: rgba(30,42,64,0.78); }
.godMiniBtn.danger{ border-color: rgba(251,113,133,0.28); }
.godSelect{
  border-radius: 999px;
  padding: 6px 10px;
  font-size: 12px;
  font-weight: 800;
  border:1px solid rgba(140,160,190,0.16);
  background: rgba(18,26,40,0.62);
  color: rgba(240,245,255,0.92);
}
.godLayoutHint{ font-size: 11px; color: rgba(210,220,245,0.72); text-align:right; }

.godGuideX, .godGuideY{
  position:absolute;
  z-index: 58;
  pointer-events:none;
  opacity:0;
  transition: opacity 120ms ease;
}
.godGuideX{ left:0; right:0; height:1px; background: rgba(94,234,242,0.28); }
.godGuideY{ top:0; bottom:0; width:1px; background: rgba(94,234,242,0.28); }

/* Optional: floating/movable cards inside panels */
.cardFloating{
  box-shadow: 0 18px 60px rgba(0,0,0,0.45);
  border-color: rgba(121,87,255,0.36);
}
.badge{ font-size:12px; padding:4px 8px; border-radius:999px; border:1px solid var(--line); color:var(--muted); }
.badge.good{ color:var(--good); border-color: rgba(52,211,153,0.3); }
.badge.bad{ color:var(--bad); border-color: rgba(251,113,133,0.3); }
.badge.warn{ color:var(--warn); border-color: rgba(251,191,36,0.3); }
.layout{
  display:grid;
  grid-template-columns: 280px 1fr;
  height:100vh;
}

/* OS wallpaper layer (Home-style glass UI) */
.layoutWide{ position: relative; }
.layoutWide::before{
  content:"";
  position: fixed;
  inset: 0;
  background-image: var(--os-wallpaper);
  background-size: cover;
  background-position: center;
  opacity: 0.16;
  filter: saturate(1.15) contrast(1.05);
  pointer-events:none;
  z-index: 0;
}
.layoutWide .rail,
.layoutWide .main,
.layoutWide .activityRail{ position: relative; z-index: 1; }
.rail{
  border-right:1px solid var(--line);
  padding:var(--card-pad);
  overflow:auto;
  background:
    radial-gradient(800px 360px at 0% 0%, rgba(37,88,202,0.18) 0%, rgba(8,12,18,0) 58%),
    radial-gradient(800px 360px at 100% 10%, rgba(196,50,127,0.12) 0%, rgba(8,12,18,0) 58%),
    rgba(8,12,18,0.70);
  display:flex;
  flex-direction:column;
  min-height:0;
}
.main{
  padding:var(--card-pad);
  overflow:auto;
  position:relative;
  background:
    radial-gradient(1100px 520px at 20% 0%, rgba(255,64,182,0.16) 0%, rgba(0,0,0,0) 55%),
    radial-gradient(900px 420px at 85% 10%, rgba(94,234,242,0.14) 0%, rgba(0,0,0,0) 58%),
    radial-gradient(1000px 520px at 60% 90%, rgba(251,191,36,0.10) 0%, rgba(0,0,0,0) 55%),
    rgba(5,8,14,0.92);
}

/* ---------- Home panel (OS-style dashboard) ---------- */
.homeRoot{ padding-bottom: 14px; }
.homeGrid{ display:grid; grid-template-columns: 320px 1fr; gap: 12px; align-items:start; }
@media(max-width: 1100px){ .homeGrid{ grid-template-columns: 1fr; } }

.homeLeft{ display:flex; flex-direction: column; gap: 12px; }
.homeWidget{ padding: 14px; }
.homeTime{ font-size: 34px; font-weight: 950; letter-spacing: 0.2px; }
.homeDate{ font-size: 12px; color: rgba(240,248,255,0.72); margin-top: 4px; }

.homeMeterRow{ display:flex; gap: 10px; }
.homeRing{ flex:1; border:1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.18); border-radius: 16px; padding: 10px; text-align:center; }
.homeRingLabel{ font-size: 11px; letter-spacing: 0.12em; color: rgba(240,248,255,0.62); text-transform: uppercase; }
.homeRingValue{ font-size: 18px; font-weight: 900; margin-top: 6px; }

.homeBar{ height: 10px; border-radius: 999px; background: rgba(255,255,255,0.06); overflow:hidden; border:1px solid rgba(255,255,255,0.08); margin-top: 8px; }
.homeBarFill{ height:100%; background: linear-gradient(90deg, rgba(94,234,242,0.55), rgba(251,191,36,0.45)); }

.homeMain{ display:flex; flex-direction: column; gap: 12px; }
.homeTop{ display:grid; grid-template-columns: 1.6fr 1fr; gap: 12px; }
@media(max-width: 980px){ .homeTop{ grid-template-columns: 1fr; } }

/* Mission control cards (Calendar-driven) */
.homeMissionRow{ display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
@media(max-width: 1100px){ .homeMissionRow{ grid-template-columns: 1fr; } }
.homeMissionCard{ padding: 14px; background: rgba(8,12,18,0.36); border:1px solid rgba(255,255,255,0.10); }
.homeMissionTop{ display:flex; justify-content: space-between; align-items:center; gap: 10px; flex-wrap: wrap; }
.homeMissionKicker{ font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(240,248,255,0.72); }
.homeMissionTitle{ font-weight: 950; font-size: 16px; margin-top: 10px; }
.homeMissionMeta{ font-size: 12px; color: rgba(240,248,255,0.68); margin-top: 6px; }
.homeMissionEmpty{ font-size: 12px; color: rgba(240,248,255,0.72); margin-top: 10px; opacity: 0.95; }
.homeMissionActions{ margin-top: 10px; gap: 8px; flex-wrap: wrap; }


/* Live lane (Calendar + activity) */
.homeOpsRow{ display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
@media(max-width: 1100px){ .homeOpsRow{ grid-template-columns: 1fr; } }
.homeOpsCard{ padding: 14px; background: rgba(8,12,18,0.34); border:1px solid rgba(255,255,255,0.10); }
.homeOpsTop{ display:flex; justify-content: space-between; align-items:center; gap: 10px; flex-wrap: wrap; }
.homeOpsKicker{ font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(240,248,255,0.72); }
.homeOpsTitle{ font-weight: 950; font-size: 16px; margin-top: 10px; }
.homeOpsMeta{ font-size: 12px; color: rgba(240,248,255,0.68); margin-top: 6px; }
.homeOpsNote{ margin-top: 10px; font-size: 12px; color: rgba(240,248,255,0.78); border:1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.16); border-radius: 14px; padding: 10px; }
.homeOpsEmpty{ font-size: 12px; color: rgba(240,248,255,0.72); margin-top: 10px; opacity: 0.95; }
.homeOpsActions{ margin-top: 10px; gap: 8px; flex-wrap: wrap; }

.homeTaskList{ display:grid; gap: 10px; margin-top: 10px; }
.homeTaskItem{ border:1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.14); border-radius: 16px; padding: 10px; }
.homeCheck{ display:flex; gap: 10px; align-items:flex-start; cursor:pointer; }
.homeCheck input{ margin-top: 3px; accent-color: rgba(94,234,242,0.9); }
.homeTaskText{ display:flex; flex-wrap: wrap; gap: 4px; }
.homeTaskTitle{ font-weight: 900; }
.homeTaskMeta{ font-size: 12px; color: rgba(240,248,255,0.62); }

.homeHeroCard{ min-height: 160px; }
.homePills{ display:flex; gap:8px; flex-wrap: wrap; margin-top: 10px; }
.homeSearchCard input{ border-radius: 14px; }

.homeSectionTitle{ font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(240,248,255,0.65); margin-top: 2px; }

.homeAppsRow{ display:grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
@media(max-width: 980px){ .homeAppsRow{ grid-template-columns: 1fr; } }

.homeAppTile{
  display:flex;
  gap: 12px;
  align-items:center;
  padding: 12px;
  border-radius: 18px;
  border:1px solid rgba(255,255,255,0.10);
  background: rgba(0,0,0,0.18);
  cursor:pointer;
  transition: transform 140ms ease, filter 140ms ease, border-color 140ms ease;
}
.homeAppTile:hover{ transform: translateY(-1px); filter: brightness(1.08) saturate(1.06); border-color: rgba(94,234,242,0.26); }

.homeAppGridTile{
  padding: 14px;
  border-radius: 18px;
  border:1px solid rgba(255,255,255,0.10);
  background: rgba(0,0,0,0.18);
  cursor:pointer;
  transition: transform 140ms ease, filter 140ms ease, border-color 140ms ease;
  text-align:left;
}
.homeAppGridTile:hover{ transform: translateY(-1px); filter: brightness(1.08) saturate(1.06); border-color: rgba(143,98,255,0.26); }

.homeAppIcon{ width: 44px; height: 44px; border-radius: 16px; display:flex; align-items:center; justify-content:center; font-size: 22px; border:1px solid rgba(255,255,255,0.10); background: rgba(255,255,255,0.04); }
.homeAppText{ min-width: 0; }
.homeAppName{ font-weight: 950; }
.homeAppSub{ font-size: 12px; color: rgba(240,248,255,0.62); margin-top: 2px; }

.homeAppsGrid{ display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
@media(max-width: 1100px){ .homeAppsGrid{ grid-template-columns: repeat(2, minmax(0, 1fr)); } }
@media(max-width: 720px){ .homeAppsGrid{ grid-template-columns: 1fr; } }

.homeBottom{ display:grid; grid-template-columns: 1.4fr 1fr; gap: 12px; }
@media(max-width: 1100px){ .homeBottom{ grid-template-columns: 1fr; } }

.homeActivity{ border:1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.16); border-radius: 16px; padding: 12px; }
.homeEmpty{ padding: 14px; }

/* ---------- Entertainment (Kodi-style) ---------- */
.entShell{
  display:grid;
  grid-template-columns: 220px 1fr;
  gap: 12px;
  align-items: start;
}
@media(max-width: 980px){ .entShell{ grid-template-columns: 1fr; } }

.entNav{
  border:1px solid rgba(255,255,255,0.10);
  background: rgba(0,0,0,0.18);
  border-radius: 18px;
  padding: 12px;
  backdrop-filter: blur(12px);
}
.entClock{ font-weight: 950; font-size: 18px; margin-bottom: 10px; opacity: 0.92; }
.entNavGroup{ display:flex; flex-direction: column; gap: 6px; }
.entNavItem{
  width:100%;
  text-align:left;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  padding: 10px 10px;
  cursor:pointer;
  color: rgba(240,248,255,0.88);
}
.entNavItem:hover{ filter: brightness(1.08) saturate(1.06); }
.entNavItem.active{ border-color: rgba(94,234,242,0.28); background: rgba(94,234,242,0.10); }

.entMain{ min-height: 520px; }
.entHero{
  border:1px solid rgba(255,255,255,0.10);
  background:
    radial-gradient(820px 340px at 0% 0%, rgba(94,234,242,0.10) 0%, rgba(0,0,0,0) 55%),
    radial-gradient(820px 340px at 100% 0%, rgba(251,191,36,0.10) 0%, rgba(0,0,0,0) 55%),
    rgba(0,0,0,0.18);
  border-radius: 18px;
  padding: 14px;
  display:grid;
  grid-template-columns: 1.4fr 0.9fr;
  gap: 12px;
  backdrop-filter: blur(12px);
}
@media(max-width: 980px){ .entHero{ grid-template-columns: 1fr; } }

.entHeroTitle{ font-size: 26px; font-weight: 950; margin-top: 2px; }
.entHeroSub{ margin-top: 6px; color: rgba(240,248,255,0.70); line-height: 1.35; }

.entNow{
  border:1px solid rgba(255,255,255,0.10);
  background: rgba(0,0,0,0.16);
  border-radius: 16px;
  padding: 12px;
}
.entNowTitle{ font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(240,248,255,0.62); margin-bottom: 6px; }

.entRowTitle{ margin-top: 12px; font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(240,248,255,0.65); }
.entRow{
  margin-top: 10px;
  display:flex;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 8px;
}

.entTile{
  width: 230px;
  min-width: 230px;
  border-radius: 18px;
  border:1px solid rgba(255,255,255,0.10);
  background: rgba(0,0,0,0.16);
  cursor:pointer;
  overflow:hidden;
  transition: transform 140ms ease, filter 140ms ease, border-color 140ms ease;
}
.entTile:hover{ transform: translateY(-2px) scale(1.02); filter: brightness(1.10) saturate(1.08); border-color: rgba(143,98,255,0.26); }

.entTileArt{
  height: 132px;
  background:
    radial-gradient(520px 220px at 20% 0%, rgba(94,234,242,0.18) 0%, rgba(0,0,0,0) 55%),
    radial-gradient(520px 220px at 90% 10%, rgba(255,64,182,0.16) 0%, rgba(0,0,0,0) 55%),
    rgba(255,255,255,0.04);
  position: relative;
}
.entTileBadge{ position:absolute; top:10px; left:10px; width:34px; height:34px; border-radius: 14px; display:flex; align-items:center; justify-content:center; border:1px solid rgba(255,255,255,0.10); background: rgba(0,0,0,0.20); }
