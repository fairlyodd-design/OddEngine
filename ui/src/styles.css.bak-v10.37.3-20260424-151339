/* v10.17.9 â€” draggable room layouts */
.homieLayoutButtons{ margin: 0 0 10px; gap: 6px; }
.homieHouseRoom.layoutMode{ box-shadow: inset 0 0 0 1px rgba(94,234,242,0.18), inset 0 0 0 999px rgba(94,234,242,0.02), inset 0 -24px 44px rgba(0,0,0,0.32); }
.homieHouseRoom.layoutMode::after{ content:"Drag layout items"; position:absolute; right:10px; top:10px; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:rgba(220,236,255,0.76); background:rgba(10,16,30,0.46); border:1px solid rgba(255,255,255,0.08); border-radius:999px; padding:4px 8px; pointer-events:none; z-index:8; }
.draggableRoomItem{ will-change: transform; }
.homieHouseRoom.gridOn::before{ content:""; position:absolute; inset:0; pointer-events:none; z-index:1; opacity:0.55; background-image:
  linear-gradient(to right, rgba(94,234,242,0.10) 1px, transparent 1px),
  linear-gradient(to bottom, rgba(94,234,242,0.10) 1px, transparent 1px);
  background-size: var(--grid-size, 16px) var(--grid-size, 16px);
  mix-blend-mode: screen;
}

.draggableRoomItem.layoutEditable{ cursor: grab; pointer-events:auto; }
.draggableRoomItem.layoutEditable:hover{ filter: brightness(1.06) saturate(1.06); }
.draggableRoomItem.layoutEditable::after{ content:""; position:absolute; inset:-6px; border-radius:16px; border:1px dashed rgba(255,255,255,0.0); transition:border-color 160ms ease, box-shadow 160ms ease, opacity 160ms ease; pointer-events:none; }
.draggableRoomItem.layoutEditable:hover::after{ border-color: rgba(255,255,255,0.18); box-shadow: 0 0 0 1px rgba(94,234,242,0.12); }
.draggableRoomItem.dragging{ cursor: grabbing; filter: brightness(1.08) saturate(1.08); }
.draggableRoomItem.dragging::after{ border-color: rgba(94,234,242,0.48); box-shadow: 0 0 0 1px rgba(94,234,242,0.22), 0 0 18px rgba(94,234,242,0.16); }
.houseLamp.draggableRoomItem.layoutEditable::after,
.housePlant.draggableRoomItem.layoutEditable::after,
.houseSideTable.draggableRoomItem.layoutEditable::after,
.houseMonitor.draggableRoomItem.layoutEditable::after{ inset:-8px; border-radius:14px; }
.houseBuddySpot.draggableRoomItem.layoutEditable::after{ inset:-10px 12px -6px 12px; border-radius:26px; }
