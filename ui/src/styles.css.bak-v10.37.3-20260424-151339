/* v10.21.3 â€” Homie Buddy animation pass (emoji/person vibe) */
.homieOrbFace{ transform-origin: center; }
.homieOrbBrow{ position:absolute; top:-1px; width: 12px; height: 3px; border-radius: 999px; background: rgba(238,246,255,0.55); opacity: 0.65; }
.homieOrbBrow.left{ left: 5px; --brow-rot: -10deg; transform: rotate(-10deg); }
.homieOrbBrow.right{ right: 5px; --brow-rot: 10deg; transform: rotate(10deg); }
.homieOrbCheek{ position:absolute; top: 16px; width: 10px; height: 6px; border-radius: 999px; background: rgba(255,122,188,0.20); filter: blur(0.2px); opacity: 0.7; }
.homieOrbCheek.left{ left: 1px; }
.homieOrbCheek.right{ right: 1px; }

/* Orb eyes: blink + pupil drift (skip Lil Homie) */
.homieOrb:not(.skin-lil-homie) .homieEye{ transform-origin: center; animation: homieOrbBlink 6.8s ease-in-out infinite; }
.homieOrb:not(.skin-lil-homie) .homieEye::after{ content:""; position:absolute; left: 2px; top: 2px; width: 3px; height: 3px; border-radius: 50%; background: rgba(10,12,20,0.92); box-shadow: 0 0 6px rgba(0,0,0,0.35); animation: homieOrbLook 9.4s ease-in-out infinite; }

/* Speaking: brows bounce + cheeks brighten */
.homieOrb.speaking:not(.skin-lil-homie) .homieOrbBrow{ animation: homieBrowTalk 420ms ease-in-out infinite; }
.homieOrb.speaking:not(.skin-lil-homie) .homieOrbCheek{ background: rgba(255,122,188,0.28); opacity: 0.85; }

/* Listening: eyes a bit bigger + more glow */
.homieOrb.listening:not(.skin-lil-homie) .homieEye{ box-shadow: 0 0 12px rgba(255,255,255,0.78); }
.homieOrb.listening:not(.skin-lil-homie) .homieOrbBrow{ opacity: 0.85; }

/* Idle gestures (class driven) */
.homieOrb.gesture-wink:not(.skin-lil-homie) .homieEye.left{ animation: none; transform: scaleY(0.18); }
.homieOrb.gesture-wink:not(.skin-lil-homie) .homieEye.left::after{ animation: none; opacity: 0; }
.homieOrb.gesture-nod .homieOrbCore{ animation: homieGestureNod 900ms ease-in-out 1; }
.homieOrb.gesture-tilt .homieOrbCore{ animation: homieGestureTilt 1200ms ease-in-out 1; }
.homieOrb.gesture-spark::before{ content:""; position:absolute; inset:-18px; border-radius:50%; background:
  radial-gradient(circle at 25% 35%, rgba(255,209,102,0.28), rgba(255,209,102,0) 35%),
  radial-gradient(circle at 70% 28%, rgba(94,234,242,0.22), rgba(94,234,242,0) 40%),
  radial-gradient(circle at 62% 78%, rgba(255,88,200,0.18), rgba(255,88,200,0) 42%);
  opacity: 0; pointer-events:none; filter: blur(0.1px); animation: homieSpark 900ms ease-out 1; }

/* Lil Homie gestures */
.homieOrb.skin-lil-homie.gesture-wave .homieLilArm.right{ animation: homieWave 650ms ease-in-out 2; }
.homieOrb.skin-lil-homie.gesture-wave .homieLilArm.left{ animation: homieWave 650ms ease-in-out 2 reverse; }
.homieOrb.skin-lil-homie.gesture-nod .homieLilHead{ animation: homieNodHead 900ms ease-in-out 1; }
.homieOrb.skin-lil-homie.gesture-tilt .homieLilBody{ animation: homieTiltBody 1200ms ease-in-out 1; }

@keyframes homieOrbBlink{ 0%, 45%, 52%, 100%{ transform: scaleY(1);} 48%{ transform: scaleY(0.14);} 50%{ transform: scaleY(0.08);} }
@keyframes homieOrbLook{ 0%,100%{ transform: translate(0,0);} 18%{ transform: translate(1px,0);} 42%{ transform: translate(0,1px);} 62%{ transform: translate(-1px,0);} 78%{ transform: translate(0,-1px);} }
@keyframes homieBrowTalk{ 0%,100%{ transform: translateY(0) rotate(var(--brow-rot, 0deg)); } 50%{ transform: translateY(-1px) rotate(var(--brow-rot, 0deg)); } }
@keyframes homieGestureNod{ 0%,100%{ transform: translateY(0);} 35%{ transform: translateY(1px);} 70%{ transform: translateY(-1px);} }
@keyframes homieGestureTilt{ 0%,100%{ transform: rotate(0deg);} 40%{ transform: rotate(-6deg);} 75%{ transform: rotate(5deg);} }
@keyframes homieSpark{ 0%{ opacity:0; transform: scale(0.96);} 30%{ opacity:0.9;} 100%{ opacity:0; transform: scale(1.12);} }
@keyframes homieNodHead{ 0%,100%{ transform: translateY(0);} 40%{ transform: translateY(1px);} 70%{ transform: translateY(-1px);} }
@keyframes homieTiltBody{ 0%,100%{ transform: rotate(0deg);} 45%{ transform: rotate(-5deg);} 80%{ transform: rotate(4deg);} }



/* v10.21.4 â€” Homie Rive game-buddy mode (modern game buddy) */
.homieRiveWrap{ position:absolute; inset: 0; display:block; }
.homieRiveClip{ position:absolute; inset: 0; border-radius: 999px; overflow: hidden; }
.homieRiveCanvas{ width: 100%; height: 100%; display:block; }
