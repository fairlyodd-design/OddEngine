/* Calendar panel */
.calendarWrap{
  display:grid;
  grid-template-columns: 1.25fr 0.75fr;
  gap:12px;
}
.calendarTop{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:12px;
  flex-wrap:wrap;
}
.calendarWeekdays{
  display:grid;
  grid-template-columns: repeat(7, 1fr);
  gap:6px;
  margin-top:10px;
  margin-bottom:6px;
}
.calendarWeekday{
  font-size:12px;
  color: var(--muted);
  text-align:center;
  letter-spacing: 0.06em;
}
.calendarGrid{
  display:grid;
  grid-template-columns: repeat(7, 1fr);
  gap:6px;
}
.calendarCell{
  border:1px solid rgba(255,255,255,0.10);
  background: rgba(0,0,0,0.18);
  border-radius:14px;
  padding:8px;
  min-height: 84px;
  cursor:pointer;
  transition: transform 120ms ease, filter 120ms ease, border-color 120ms ease;
  overflow:hidden;
}
.calendarCell:hover{ filter: brightness(1.06) saturate(1.05); }
.calendarCell.selected{ border-color: rgba(94,234,242,0.32); box-shadow: 0 0 0 1px rgba(94,234,242,0.12) inset; }
.calendarCell.today{ border-color: rgba(251,191,36,0.35); box-shadow: 0 0 0 1px rgba(251,191,36,0.10) inset; }
.calendarCell.outMonth{ opacity: 0.55; }
.calendarCellTop{ display:flex; align-items:center; justify-content:space-between; gap:8px; }
.calendarDayNum{ font-weight: 900; }
.calendarDotRow{ display:flex; gap:4px; align-items:center; }
.calendarDot{ width:6px; height:6px; border-radius:999px; background: rgba(94,234,242,0.75); display:inline-block; }
.calendarCellPeek{ margin-top:8px; display:grid; gap:4px; }
.calendarPeekLine{ display:flex; gap:6px; align-items:center; font-size:12px; color: rgba(240,248,255,0.88); }
.calendarPeekTime{ color: rgba(210,220,245,0.70); min-width: 44px; }
.calendarPeekTitle{ overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }

@media (max-width: 980px){
  .calendarWrap{ grid-template-columns: 1fr; }
}

