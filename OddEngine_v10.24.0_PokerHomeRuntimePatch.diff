+async function sampleCpuUsagePercent(sampleMs = 240){
+  const snap = () => {
+    const cpus = os.cpus() || [];
+    let idle = 0;
+    let total = 0;
+    for(const cpu of cpus){
+      const times = cpu && cpu.times ? cpu.times : {};
+      const cpuIdle = Number(times.idle || 0);
+      const cpuTotal = Object.values(times).reduce((sum, val) => sum + Number(val || 0), 0);
+      idle += cpuIdle;
+      total += cpuTotal;
+    }
+    return { idle, total, cores: cpus.length || 0 };
+  };
+  const a = snap();
+  await new Promise((resolve) => setTimeout(resolve, sampleMs));
+  const b = snap();
+  const idleDelta = Math.max(0, b.idle - a.idle);
+  const totalDelta = Math.max(1, b.total - a.total);
+  const percentUsed = Math.max(0, Math.min(100, Math.round((1 - (idleDelta / totalDelta)) * 100)));
+  return { percentUsed, cores: b.cores || a.cores || 0 };
+}
+
+function getMemoryStats(){
+  const total = Number(os.totalmem() || 0);
+  const free = Number(os.freemem() || 0);
+  const used = Math.max(0, total - free);
+  const percentUsed = total > 0 ? Math.max(0, Math.min(100, Math.round((used / total) * 100))) : 0;
+  return { total, free, used, percentUsed };
+}
+
+function getPrimaryNetworkStats(){
+  const hostname = os.hostname();
+  const nets = os.networkInterfaces ? os.networkInterfaces() : {};
+  let best = null;
+  for(const [name, list] of Object.entries(nets || {})){
+    for(const item of list || []){
+      const family = typeof item.family === "string" ? item.family : String(item.family || "");
+      if(item && !item.internal && family === "IPv4"){
+        const address = String(item.address || "").trim();
+        if(address){
+          best = { hostname, primaryIp: address, interfaceName: String(name || "") };
+          break;
+        }
+      }
+    }
+    if(best) break;
+  }
+  return best || { hostname, primaryIp: "", interfaceName: "" };
+}
+
+function getStorageStats(){
+  try{
+    const basePath = app.getPath("userData");
+    const rootPath = path.parse(basePath).root || basePath;
+    if(typeof fs.statfsSync !== "function"){
+      return { path: rootPath, total: 0, free: 0, used: 0, percentUsed: 0 };
+    }
+    const stat = fs.statfsSync(rootPath);
+    const blockSize = Number(stat.bsize || stat.frsize || 0);
+    const total = blockSize > 0 ? Number(stat.blocks || 0) * blockSize : 0;
+    const free = blockSize > 0 ? Number(stat.bavail || stat.bfree || 0) * blockSize : 0;
+    const used = Math.max(0, total - free);
+    const percentUsed = total > 0 ? Math.max(0, Math.min(100, Math.round((used / total) * 100))) : 0;
+    return { path: rootPath, total, free, used, percentUsed };
+  }catch(err){
+    return { path: "", total: 0, free: 0, used: 0, percentUsed: 0, error: String(err) };
+  }
+}
